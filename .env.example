# --- Auth service (Better Auth) ---
# Used by the browser for sign-in (Microsoft redirect / owner email+password) AND by
# this app's server to mint the API JWT. The auth URL is public anyway (OAuth redirects),
# so it's exposed to the browser; the JWT and the .NET API are never touched by the browser.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8088
NEXT_PUBLIC_AUTH_BASE_PATH=/api/auth

# --- .NET API ---
# Server-only. The browser never calls this directly; the BFF proxies every call and
# attaches the Bearer JWT server-side.
API_BASE_URL=http://localhost:8080

# --- Report email (AWS SES) ---
# Server-only. Used by "Send now" / scheduled report emails. SES credentials are
# DEDICATED (SES_ACCESS_KEY_ID / SES_SECRET_ACCESS_KEY) and kept separate from the
# generic AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY pair that DigitalOcean Spaces uses.
# If the SES_* keys are unset, the AWS default chain is used. Email no-ops with a
# warning if SES_FROM_EMAIL is unset. NEXT_PUBLIC_CRM_URL is the public CRM origin used
# to link back to the report in emails.
SES_REGION=us-east-1
SES_FROM_EMAIL=
SES_FROM_NAME=Mercado Ahorros
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
NEXT_PUBLIC_CRM_URL=http://localhost:8102
