# --- Auth service (Better Auth) ---
# Used by the browser for sign-in (Microsoft redirect / owner email+password) AND by
# this app's server to mint the API JWT. The auth URL is public anyway (OAuth redirects),
# so it's exposed to the browser; the JWT and the .NET API are never touched by the browser.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8088
NEXT_PUBLIC_AUTH_BASE_PATH=/api/auth

# --- .NET API ---
# Server-only. The browser never calls this directly; the BFF proxies every call and
# attaches the Bearer JWT server-side.
API_BASE_URL=http://localhost:8080
